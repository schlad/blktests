#
# Regression test for blk_mq tag starvation triggered by btrfs under BFQ.
# When btrfs mounts a device with a shallow request queue and BFQ enabled,
# caching_thread (reading the v2 free space tree) and btrfs-transacti
# (committing dirty block groups) can simultaneously exhaust all available
# request tags and block indefinitely in blk_mq_get_tag.
#
# Observed on Intel C600 SAS (isci) hardware in a kdump kernel,
# kernel 6.4.0-150700.53.60-default.
#
# A dm-delay device is layered over null_blk to hold each IO in flight for
# _DM_DELAY_MS milliseconds, simulating the slow or stuck isci controller.
# Setup (mkfs, pre-populate) runs directly against null_blk without the
# delay so the test completes in reasonable time.

. tests/block/rc
. common/null_blk

DESCRIPTION="btrfs free space caching tag starvation under BFQ with shallow queue"

_DM_NAME=blktests_044_delay
# IO delay applied via dm-delay.  Must exceed hung_task_timeout_secs (set to
# 2 below) so that any thread stuck waiting for a tag is caught by the hung
# task detector before a completion arrives.
_DM_DELAY_MS=3000

_cleanup_044() {
	[[ -n "${ORIG_HUNG_TIMEOUT:-}" ]] && \
		echo "$ORIG_HUNG_TIMEOUT" > /proc/sys/kernel/hung_task_timeout_secs
	# Signal fio early but do not wait yet: if fio is stuck in D-state
	# inside blk_mq_get_tag it cannot receive signals until a tag is freed.
	[[ -n "${FIO_PID:-}" ]] && kill "$FIO_PID" 2>/dev/null
	[[ -n "${MNT:-}" ]] && umount -l "$MNT" 2>/dev/null
	[[ -n "${MNT:-}" ]] && rm -rf "$MNT"
	# Force-remove the dm device before waiting for fio.  This completes
	# all pending dm-delay IOs with EIO, freeing their tags and unblocking
	# any kernel threads (caching_thread, btrfs-transacti) or fio jobs
	# that were stuck in blk_mq_get_tag.
	dmsetup remove --force "$_DM_NAME" 2>/dev/null
	# Allow time for dm-delay timers to fire and for btrfs to process the
	# IO errors before we pull null_blk away.
	sleep $(( (_DM_DELAY_MS / 1000) + 2 ))
	# fio can now exit since its blocked IOs have been errored out.
	[[ -n "${FIO_PID:-}" ]] && wait "$FIO_PID" 2>/dev/null
	_exit_null_blk
}

requires() {
	_have_null_blk
	_have_module_param null_blk memory_backed
	_have_kernel_option IOSCHED_BFQ
	_have_fs btrfs
	_have_program mkfs.btrfs
	_have_fio
	_have_program dmsetup
	_have_driver dm_delay
}

test() {
	echo "Running ${TEST_NAME}"

	# null_blk: large queue depth — the bottleneck is the dm-delay device
	# sitting on top, not the underlying device.
	if ! _configure_null_blk nullb1 \
			irqmode=2 \
			completion_nsec=5000000 \
			submit_queues=1 \
			hw_queue_depth=64 \
			memory_backed=1 \
			size=1024 \
			power=1; then
		return 1
	fi

	_register_test_cleanup _cleanup_044

	local dev=/dev/nullb1
	MNT=$(mktemp -d)

	mkfs.btrfs -f "$dev" >> "$FULL" 2>&1

	# Pre-populate and fragment free space directly on null_blk (no delay)
	# so caching_thread has real work — multiple bio reads of the free space
	# tree — on the next mount.
	mount -o space_cache=v2 "$dev" "$MNT"
	local i
	for i in $(seq 1 500); do
		dd if=/dev/zero of="$MNT/f$i" bs=4k count=64 2>/dev/null
	done
	for i in $(seq 2 2 500); do
		rm -f "$MNT/f$i"
	done
	sync
	umount "$MNT"

	# Layer dm-delay over null_blk.  Every IO through this device takes
	# _DM_DELAY_MS ms to complete, keeping request tags in flight long
	# enough for the hung task detector to fire.
	local sectors
	sectors=$(blockdev --getsz "$dev")
	echo "0 $sectors delay $dev 0 $_DM_DELAY_MS" | \
		dmsetup create "$_DM_NAME" >> "$FULL" 2>&1

	local dm_dev=/dev/mapper/$_DM_NAME
	local dm_minor
	dm_minor=$(dmsetup info -c --noheadings -o minor "$_DM_NAME")
	local dm_queue=/sys/block/dm-${dm_minor}/queue

	# Shallow queue + BFQ on the dm device to reproduce the isci kdump
	# environment: BFQ limits writes to ~75% of nr_requests leaving reads
	# from caching_thread (unrestricted by BFQ) to compete for the rest.
	echo bfq > "$dm_queue/scheduler"
	# Single tag: the mount process takes it for each sequential tree read
	# (3s per IO, returned promptly).  The caching_threads that btrfs
	# queues during open_ctree all try to read simultaneously and pile up
	# in blk_mq_get_tag behind each other.  With N caching_threads queued,
	# the Nth thread waits N*_DM_DELAY_MS ms — well above hung_task_timeout.
	echo 1 > "$dm_queue/nr_requests"

	# Capture the dmesg baseline and set hung_task_timeout BEFORE mount so
	# we catch starvation that starts during open_ctree (caching_threads
	# begin competing for the single tag as soon as they are queued, while
	# the mount process is still holding it for its own sequential reads).
	# A single 3s read (folio_wait_bit) is below the 4s threshold so the
	# mount process itself does not produce false positives.
	ORIG_HUNG_TIMEOUT=$(cat /proc/sys/kernel/hung_task_timeout_secs)
	echo 4 > /proc/sys/kernel/hung_task_timeout_secs

	local dmesg_lines_before
	dmesg_lines_before=$(dmesg | wc -l)

	mount -o space_cache=v2 "$dm_dev" "$MNT"

	# fio adds transaction-commit pressure (btrfs-transacti reads) on top
	# of the caching_thread reads already saturating the single tag.
	fio --filename="$MNT/workload" --size=128M --bs=4k --rw=randwrite \
		--ioengine=sync --numjobs=4 --name=txpressure \
		--runtime=20 --time_based >> "$FULL" 2>&1 &
	FIO_PID=$!

	local elapsed=0 hung=0
	while (( elapsed < 60 )); do
		if ! kill -0 "$FIO_PID" 2>/dev/null; then
			break
		fi
		if dmesg | tail -n +"$((dmesg_lines_before + 1))" | \
				grep -q "blk_mq_get_tag"; then
			hung=1
			break
		fi
		sleep 2
		(( elapsed += 2 ))
	done

	if (( hung )); then
		echo "FAIL: btrfs tag starvation deadlock detected in dmesg"
		return 1
	fi

	echo "Test complete"
}
